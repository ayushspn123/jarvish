# Copy this file to ".env" and fill in your values.

# Required: your API key.
#   OpenAI key   -> https://platform.openai.com/api-keys   (starts with "sk-")
#   OpenRouter   -> https://openrouter.ai/keys              (starts with "sk-or-")
# OpenRouter keys are auto-detected and routed correctly — no other change needed.
OPENAI_API_KEY=sk-...

# Optional: which model JARVIS uses as its brain.
#   OpenAI:     gpt-4o-mini (cheap/fast) or gpt-4o (smarter)
#   OpenRouter: use provider-prefixed names, e.g. openai/gpt-4o-mini, anthropic/claude-3.5-sonnet
# Leave blank to use a sensible default for your key type.
JARVIS_MODEL=

# Optional: override the API endpoint (advanced). Auto-set for OpenRouter keys.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional: assistant name and your name (so JARVIS addresses you naturally)
JARVIS_NAME=JARVIS
JARVIS_OWNER=Ayush

# Optional: the neural voice JARVIS speaks in (used in --voice mode).
# Examples: en-IN-PrabhatNeural (Indian male), en-IN-NeerjaNeural (Indian female),
#           en-GB-RyanNeural (British male), en-US-AriaNeural (US female).
# Full list:  python -m edge_tts --list-voices
JARVIS_TTS_VOICE=en-IN-PrabhatNeural

# Optional: how fast JARVIS speaks. "+18%" is a bit quick; use "+30%" for faster,
# "+0%" for normal, "-10%" for slower.
JARVIS_TTS_RATE=+30%

# Optional: the wake words that activate JARVIS in voice mode (comma-separated).
# Speech recognition sometimes mishears "jarvis", so a few variants are included.
# Say "Hey <wake word>" to activate. Keep these short and distinctive.
JARVIS_WAKE_WORD=jarvis,jarvish,jervis

# Optional: let you interrupt JARVIS by talking while it's speaking ("barge-in").
# You can ALWAYS interrupt by pressing any key, then speaking. Voice interrupt ("stop"/"wait")
# works best with HEADPHONES — on open laptop speakers JARVIS may hear its own voice (an echo
# filter reduces this). Set to false to disable voice interrupt and use keypress only.
JARVIS_BARGE_IN=true

# Optional: which voice JARVIS speaks in.
#   "edge"  -> fast neural voice (JARVIS_TTS_VOICE above)
#   "clone" -> YOUR cloned voice via the local OpenVoice server (needs voice_clone setup +
#              a recording at voice_clone/reference.wav; ~5s per reply on CPU)
JARVIS_TTS_ENGINE=clone
# Where the local clone server listens, and which recording to clone from.
JARVIS_CLONE_URL=http://127.0.0.1:5111
JARVIS_VOICE_SAMPLE=voice_clone/reference.wav
